\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/05/01 NeurIPS 2024 Paper Style]
\newif\if@neuripsfinal\@neuripsfinalfalse
\newif\if@preprint\@preprintfalse
\DeclareOption{final}{\@neuripsfinaltrue}
\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{nonatbib}{}
\ProcessOptions\relax
\RequirePackage[verbose=true,letterpaper]{geometry}
\geometry{textheight=9in,textwidth=5.5in,top=1in,headheight=12pt,headsep=25pt,footskip=30pt}
\RequirePackage{times}
\RequirePackage{amsmath,amssymb}
\RequirePackage{url}
\setlength{\parindent}{0pt}
\setlength{\parskip}{4pt}
\RequirePackage[font=small,labelfont=bf]{caption}
\def\@maketitle{%
  \newpage\begin{center}%
  {\LARGE\bfseries\@title\par}\vskip1em%
  {\large\@author}\end{center}\par\vskip1.5em}
\renewenvironment{abstract}{\centerline{\large\bf Abstract}\vspace{0.5ex}\begin{quote}}{\end{quote}\vskip1ex}
\RequirePackage{fancyhdr}
\pagestyle{plain}
\endinput
